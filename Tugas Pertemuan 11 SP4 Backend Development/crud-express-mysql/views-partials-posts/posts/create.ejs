<%- include('../partials/header') %>

<main>
    <div class="page-header">
        <div class="page-title-group">
            <h1>Create Publication</h1>
            <p>Publish a new thought, tutorial, or quick note to the dashboard</p>
        </div>
    </div>

    <div class="form-card">
        <form action="/posts/store" method="POST" novalidate>
            <!-- Title Input -->
            <div class="form-group">
                <label for="title" class="form-label">Title</label>
                <input 
                    type="text" 
                    id="title" 
                    name="title" 
                    class="form-control <%= (errors && errors.title) ? 'is-invalid' : '' %>" 
                    placeholder="Enter an engaging title..." 
                    value="<%= typeof formData !== 'undefined' && formData.title ? formData.title : '' %>" 
                    required
                >
                <% if (errors && errors.title) { %>
                    <div class="invalid-feedback"><%= errors.title.msg || errors.title %></div>
                <% } %>
            </div>

            <!-- Content Textarea -->
            <div class="form-group">
                <label for="content" class="form-label">Content</label>
                <textarea 
                    id="content" 
                    name="content" 
                    class="form-control <%= (errors && errors.content) ? 'is-invalid' : '' %>" 
                    placeholder="Write your publication content here..." 
                    required
                ><%= typeof formData !== 'undefined' && formData.content ? formData.content : '' %></textarea>
                <% if (errors && errors.content) { %>
                    <div class="invalid-feedback"><%= errors.content.msg || errors.content %></div>
                <% } %>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
                <a href="/posts" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                    Publish Post
                </button>
            </div>
        </form>
    </div>
</main>

<%- include('../partials/footer') %>

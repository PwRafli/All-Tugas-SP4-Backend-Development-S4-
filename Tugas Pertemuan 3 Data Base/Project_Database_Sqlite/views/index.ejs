<!DOCTYPE html>
<html>

<head>

    <title>Hotel Room List</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

</head>

<body class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">

        <h2>Hotel Room List</h2>

        <form class="d-flex" method="GET" action="/">

            <input type="text" name="search" value="<%= search %>" class="form-control me-2"
                placeholder="Search room...">

            <button class="btn btn-success">Search</button>

        </form>

    </div>

    <a href="/add" class="btn btn-primary mb-3">Add New Room</a>

    <table class="table table-dark table-striped">

        <thead>

            <tr>
                <th>Photo</th>
                <th>Code</th>
                <th>Name</th>
                <th>Description</th>
                <th>Size</th>
                <th>Price</th>
                <th>Guests</th>
                <th>Available</th>
                <th>Action</th>
            </tr>

        </thead>

        <tbody>

            <% rooms.forEach(room=> { %>

                <tr>

                    <td>
                        <img src="/uploads/<%= room.photo %>" width="70">
                    </td>

                    <td>
                        <%= room.code_room %>
                    </td>
                    <td>
                        <%= room.name %>
                    </td>
                    <td>
                        <%= room.description %>
                    </td>
                    <td>
                        <%= room.room_size %>
                    </td>
                    <td>
                        <%= room.price %>
                    </td>
                    <td>
                        <%= room.guests %>
                    </td>
                    <td>
                        <%= room.available %>
                    </td>

                    <td>

                        <a href="/edit/<%= room.id %>" class="btn btn-warning btn-sm">Edit</a>

                        <form action="/delete/<%= room.id %>" method="POST" class="d-inline"
                            onsubmit="return confirm('Delete room?')">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>

                    </td>

                </tr>

                <% }) %>

        </tbody>

    </table>

</body>

</html>
